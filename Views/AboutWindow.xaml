<Window x:Class="TraceMatch.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 TraceMatch" Height="260" Width="430"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F7F8F5">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="TraceMatch" FontSize="28" FontWeight="Bold" Foreground="#17231E"/>
            <TextBlock Text="药品追溯码到货比对工具" Margin="0,6,0,0" Foreground="#5B6B62"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,20,0,0">
            <TextBlock x:Name="VersionText" FontWeight="SemiBold"/>
            <TextBlock x:Name="StatusText" Margin="0,12,0,0" Foreground="#59665F" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="检查更新" Width="96" Height="34" Margin="0,0,8,0" Click="CheckUpdate_Click"/>
            <Button Content="关闭" Width="82" Height="34" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
