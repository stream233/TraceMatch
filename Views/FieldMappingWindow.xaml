<Window x:Class="TraceMatch.Views.FieldMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="字段映射" Height="480" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F7F8F5">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="字段映射" FontSize="22" FontWeight="SemiBold" Foreground="#1E2A24"/>
            <TextBlock Text="把导入文件中的列名对应到系统字段，追溯码为必填。" Margin="0,6,0,14" Foreground="#5D6A61"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="MappingPanel"/>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,18,0,0">
            <TextBlock DockPanel.Dock="Left" Text="字段名变化时只需在这里重新选择列。" Foreground="#6B746C" VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="82" Height="34" Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button Content="确定" Width="92" Height="34" Background="#1F6F4A" Foreground="White" Click="Ok_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
