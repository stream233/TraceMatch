<Window x:Class="TraceMatch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TraceMatch.Converters"
        Title="药品追溯码到货比对" Height="860" Width="1280" MinHeight="720" MinWidth="1100"
        Background="#EEF1EC" Loaded="Window_Loaded">
    <Window.Resources>
        <conv:StatusBrushConverter x:Key="StatusBrushConverter"/>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#214C3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#CAD2C8"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="LabelText">
            <Setter Property="Foreground" Value="#536059"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,18">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="TraceMatch" FontSize="34" FontWeight="Bold" Foreground="#17231E"/>
                <TextBlock Text="药品追溯码到货比对工作台" FontSize="15" Foreground="#5B6B62" Margin="2,2,0,0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="16,8,0,0">
                <Button Content="关于" Command="{Binding ShowAboutCommand}" Width="78" Margin="0,0,8,0" Background="#4F654F"/>
                <ComboBox Width="520" Height="36"
                          ItemsSource="{Binding Orders}" SelectedItem="{Binding CurrentOrder}"
                          DisplayMemberPath="DisplayName"
                          HorizontalContentAlignment="Center"
                          VerticalContentAlignment="Center">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
                <Button Content="&#x5220;&#x9664;&#x9A8C;&#x6536;&#x5355;" Command="{Binding DeleteOrderCommand}" Width="120" Margin="8,0,0,0" Background="#8A2F2F"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Background="#FBFCFA" BorderBrush="#D8DED6" BorderThickness="1" Padding="16" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="验收单号" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding OrderNumber, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="供应商（导入后自动识别）" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding Supplier, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="操作员" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding Operator, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock Text="备注" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <Button Grid.Column="4" Content="新建验收单" Command="{Binding CreateOrderCommand}" Width="120" VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Button Content="导入平台发货数据" Command="{Binding ImportShipmentCommand}" Width="150"/>
                <Button Content="&#x5BFC;&#x5165;&#x6761;&#x7801;&#x626B;&#x63CF;&#x6570;&#x636E;" Command="{Binding ImportScanCommand}" Width="150"/>
                <Button Content="重新比对" Command="{Binding CompareCommand}" Width="104"/>
                <Button Content="&#x4FDD;&#x5B58;" Command="{Binding SaveRecordsCommand}" Width="104" Background="#2F6349"/>
                <Button Content="导出 Excel" Command="{Binding ExportExcelCommand}" Width="104" Background="#516B37"/>
                <Button Content="导出 PDF" Command="{Binding ExportPdfCommand}" Width="104" Background="#65533B"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="#59665F" TextAlignment="Right"/>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <UniformGrid Grid.Row="0" Columns="6" Margin="0,0,0,14">
                <Border Background="#17231E" Padding="14" Margin="0,0,8,0">
                    <StackPanel><TextBlock Text="应到数量" Foreground="#AAB7AE"/><TextBlock Text="{Binding Stats.ExpectedCount}" Foreground="White" FontSize="26" FontWeight="Bold"/></StackPanel>
                </Border>
                <Border Background="#22332B" Padding="14" Margin="0,0,8,0">
                    <StackPanel><TextBlock Text="扫描数量" Foreground="#AAB7AE"/><TextBlock Text="{Binding Stats.ScannedCount}" Foreground="White" FontSize="26" FontWeight="Bold"/></StackPanel>
                </Border>
                <Border Background="#248552" Padding="14" Margin="0,0,8,0">
                    <StackPanel><TextBlock Text="匹配数量" Foreground="#DDEFE5"/><TextBlock Text="{Binding Stats.MatchedCount}" Foreground="White" FontSize="26" FontWeight="Bold"/></StackPanel>
                </Border>
                <Border Background="#DB7E26" Padding="14" Margin="0,0,8,0">
                    <StackPanel><TextBlock Text="未到货" Foreground="#FFE8D1"/><TextBlock Text="{Binding Stats.MissingCount}" Foreground="White" FontSize="26" FontWeight="Bold"/></StackPanel>
                </Border>
                <Border Background="#C42E2E" Padding="14" Margin="0,0,8,0">
                    <StackPanel><TextBlock Text="多到货" Foreground="#FFDCDC"/><TextBlock Text="{Binding Stats.ExtraCount}" Foreground="White" FontSize="26" FontWeight="Bold"/></StackPanel>
                </Border>
                <Border Background="#B29216" Padding="14">
                    <StackPanel><TextBlock Text="重复扫码" Foreground="#FFF1BF"/><TextBlock Text="{Binding Stats.DuplicateCount}" Foreground="White" FontSize="26" FontWeight="Bold"/></StackPanel>
                </Border>
            </UniformGrid>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Results}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" RowHeight="36" FontSize="13"
                      Background="White" BorderBrush="#D8DED6" BorderThickness="1">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                    <Style TargetType="TextBlock" x:Key="CenteredCellText">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="TextAlignment" Value="Center"/>
                    </Style>
                    <Style TargetType="TextBox" x:Key="CopyableCellText">
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="VerticalAlignment" Value="Stretch"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="IsReadOnly" Value="True"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <EventSetter Event="MouseDoubleClick" Handler="TraceCodeTextBox_MouseDoubleClick"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="状态" Width="92">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Status, Converter={StaticResource StatusBrushConverter}}" CornerRadius="2" Padding="7,3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="追溯码" Width="2.3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding TraceCode}" Style="{StaticResource CopyableCellText}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="药品名称" Binding="{Binding DrugName}" Width="1.8*" ElementStyle="{StaticResource CenteredCellText}"/>
                    <DataGridTextColumn Header="规格" Binding="{Binding Specification}" Width="1.1*" ElementStyle="{StaticResource CenteredCellText}"/>
                    <DataGridTextColumn Header="批号" Binding="{Binding BatchNumber}" Width="1.1*" ElementStyle="{StaticResource CenteredCellText}"/>
                    <DataGridTextColumn Header="生产企业" Binding="{Binding Manufacturer}" Width="1.7*" ElementStyle="{StaticResource CenteredCellText}"/>
                    <DataGridTextColumn Header="生产日期" Binding="{Binding ProductionDate}" Width="150" ElementStyle="{StaticResource CenteredCellText}"/>
                    <DataGridTextColumn Header="有效期" Binding="{Binding ExpiryDate}" Width="1*" ElementStyle="{StaticResource CenteredCellText}"/>
                    <DataGridTextColumn Header="数量" Binding="{Binding Quantity}" Width="80" ElementStyle="{StaticResource CenteredCellText}"/>
                    <DataGridTextColumn Header="扫描时间" Binding="{Binding ScannedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="150" ElementStyle="{StaticResource CenteredCellText}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <TextBlock Grid.Row="4" Margin="0,12,0,0" Foreground="#718077"
                   Text="数据保存在本机 SQLite，导入与比对后会立即写入数据库。MVP 不包含自动下载、上传或 ERP 集成。"/>
    </Grid>
</Window>
